{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/sim/**/*",
    "src/schema/**/*",
    "src/shared/**/*",
    "src/preload/*.d.ts",
    "src/__test-helpers__/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@sim/*": ["src/sim/*"],
      "@schema/*": ["src/schema/*"],
      "@shared/*": ["src/shared/*"],
      "@test-helpers/*": ["src/__test-helpers__/*"]
    }
  }
}
